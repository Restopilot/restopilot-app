id, name, address, color, objectives (JSONB), date_overrides (JSONB), created_at

### Table `app_users`
id, email, password, name, role (admin/manager), restaurant_id, created_at

### Table `daily_data`
id, restaurant_id, date, ca, ca_ht, objectif, updated_at

### Table `invoices`
id, restaurant_id, date, fournisseur, montant, categorie

### Table `suppliers`
id, name, category, restaurant_id, active

### Table `alert_recipients`
id, email, name, active

